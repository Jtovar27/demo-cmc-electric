# Database
# Local dev (SQLite):    DATABASE_URL="file:dev.db"
# Production (Turso):    DATABASE_URL="libsql://your-db.turso.io"
DATABASE_URL="file:dev.db"

# Auth (generate a strong secret for production)
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://your-domain.vercel.app"

# Turso auth token (production only — leave empty for local dev)
TURSO_AUTH_TOKEN=""
